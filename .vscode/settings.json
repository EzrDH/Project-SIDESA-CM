{
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "[dart]": {
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.rulers": [100]
  },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "dart.lineLength": 100,
  "files.exclude": {
    "**/node_modules": true,
    "**/build": true,
    "**/.dart_tool": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/build": true,
    "**/package-lock.json": true
  }
}
